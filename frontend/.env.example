# Frontend does not use its own .env file.
#
# Vite loads environment variables from the repo root (see vite.config.ts envDir).
# Copy the root template and edit ../.env:
#
#   cp ../.env.example ../.env
#
# Frontend-relevant keys in ../.env:
#   (Recommended) Omit VITE_API_URL in dev — Vite proxies /api to the backend (no CORS).
#   VITE_API_URL=http://localhost:4000   # only if you need direct cross-origin API calls
#   VITE_GOOGLE_CLIENT_ID=<same value as GOOGLE_CLIENT_ID>
