# ═══════════════════════════════════════════════════
# Sefinet Al Neja — Environment Variables
# Copy to .env:  cp .env.example .env
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════
#
# Local Docker dev: values below match docker-compose.yml,
# sql/init.sql, and sql/pgbouncer-userlist.txt.
# Change all secrets before production deployment.

# ── PostgreSQL ──────────────────────────────────────
POSTGRES_DB=sefinet_db
POSTGRES_ADMIN_USER=sefinet_admin
POSTGRES_ADMIN_PASSWORD=devpassword123
POSTGRES_APP_USER=sefinet_app
POSTGRES_APP_PASSWORD=apppassword123

# ── Backend Database URLs (host machine / local tools) ─
# App via PgBouncer on host port 6432
DATABASE_URL=postgresql://sefinet_app:apppassword123@localhost:6432/sefinet_db
# Migrations / seed via direct Postgres on host port 5432
DATABASE_ADMIN_URL=postgresql://sefinet_admin:devpassword123@localhost:5432/sefinet_db

# ── JWT (min 16 chars; rotate in production) ────────
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Email (SMTP) ────────────────────────────────────
# Dev: MailHog (docker compose) — http://localhost:8025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sefinet Al Neja <noreply@sefinet.et>

# ── Application ──────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
# Vite loads VITE_* from this file (see frontend/vite.config.ts envDir).
# Local dev: leave VITE_API_URL unset so requests use relative /api and the Vite proxy
# (same origin → no browser CORS). Set only when the SPA must call the API host directly:
# VITE_API_URL=http://localhost:4000
RESET_TOKEN_EXPIRY_HOURS=1
UPLOAD_DIR=/app/uploads
TZ=Africa/Addis_Ababa

# ── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Google OAuth (Google Cloud Console → APIs & Services → Credentials) ─
# Web client → Authorized JavaScript origins (scheme + host + port, no path):
#   http://localhost:5173
#   http://127.0.0.1:5173
# Add http://localhost:5174 too if Vite falls back when 5173 is busy.
# Must match the browser address bar exactly (localhost ≠ 127.0.0.1).
# Authorized redirect URIs (only if using server redirect flow):
#   GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback
VITE_GOOGLE_CLIENT_ID=
