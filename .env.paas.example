# ═══════════════════════════════════════════════════
# PaaS staging template (Render + Vercel)
# Copy values into Render / Vercel dashboards — NOT into committed .env
# ═══════════════════════════════════════════════════

# ── Render: PostgreSQL ─────────────────────────────
# From Render Postgres → Connections → Internal Database URL
DATABASE_URL=postgresql://USER:PASS@HOST/DATABASE
DATABASE_ADMIN_URL=postgresql://USER:PASS@HOST/DATABASE

# ── Render: Web service ────────────────────────────
NODE_ENV=production
PORT=4000

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-char-random-hex
JWT_REFRESH_SECRET=replace-with-different-64-char-random-hex

# Set AFTER Vercel deploy — must match browser URL exactly (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sefinet Al Neja <noreply@yourdomain.com>

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Vercel: frontend only ──────────────────────────
VITE_API_URL=https://your-api.onrender.com
VITE_GOOGLE_CLIENT_ID=
